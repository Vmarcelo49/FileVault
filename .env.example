# Port the local server will bind to
PORT=3000

# Path to the directory where files are stored (created automatically if it doesn't exist)
SHARED_DIR=./shared

# (Optional) Request a specific subdomain from localtunnel.
# Keep empty for a random subdomain.
SUBDOMAIN=

# If true, tunnels will not be initialized, and the server will only run locally.
LOCAL_ONLY=false

# Tunnel provider to start first. Options: 'localtunnel', 'cloudflare', 'zrok'.
# If the selected provider fails, the server will automatically fall back to the next available.
TUNNEL_PROVIDER=localtunnel

# (Optional) Access token for basic security.
# Keep empty to allow public access without token authentication.
AUTH_TOKEN=
